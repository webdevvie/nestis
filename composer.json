{
  "name": "webdevvie/nestis",
  "version": "2.0.0",
  "description": "A simple php class that allows for the retrieval of nested object without null checks",
  "keywords": ["nested","object","bystring"],
  "license": "Apache-2.0",
  "authors": [
    {
      "name": "John Bakker",
      "email": "me@johnbakker.name"
    }
  ],
  "minimum-stability": "dev",
  "require": {
    "php": "^8.2"
  },
  "require-dev": {
    "phpunit/phpunit": ">=11",
    "rector/rector": "dev-main"
  },
  "autoload": {
    "psr-0": { "Webdevvie\\Nestis": "src/" }
  },
  "target-dir": "Webdevvie/Nestis",
  "config": {
    "sort-packages": true,
    "bin-dir": "bin"
  }
}
